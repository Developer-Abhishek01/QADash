# ========================================
# GLOBAL ENVIRONMENT
# ========================================
NODE_ENV=development

# ========================================
# DATABASE - PostgreSQL
# ========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qadash

# ========================================
# REDIS
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# JWT
# ========================================
JWT_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# ========================================
# API URLs
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
BACKEND_API_URL=http://localhost:3001
AI_ENGINE_URL=http://localhost:3002

# ========================================
# K6 Performance Testing
# ========================================
K6_BIN=k6
K6_OUT_HTTP_API_URL=http://backend:3001/api/performance/metrics
K6_OUT_HTTP_BEARER_TOKEN=

# ========================================
# OWASP ZAP
# ========================================
ZAP_API_URL=http://zap:8080
ZAP_API_KEY=CHANGE_ME_ZAP_API_KEY

# ========================================
# Monitoring
# ========================================
GRAFANA_PASSWORD=admin123
ELASTIC_PASSWORD=elastic123