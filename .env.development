# ========================================
# QADASH ENTERPRISE - DEVELOPMENT ENVIRONMENT
# ========================================
# Local development configuration
# ========================================

# ========================================
# GLOBAL SETTINGS
# ========================================
NODE_ENV=development
PORT=3001

# ========================================
# DATABASE - PostgreSQL
# ========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qadash_dev

# ========================================
# REDIS
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# JWT AUTHENTICATION
# ========================================
JWT_SECRET=qadash-dev-secret-key-do-not-use-in-production
JWT_EXPIRES_IN=7d

# ========================================
# API CONFIGURATION
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
BACKEND_API_URL=http://localhost:3001

# ========================================
# AI ENGINE
# ========================================
AI_ENGINE_URL=http://localhost:3002
AI_MODEL=gpt-3.5-turbo
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# ========================================
# MINIO (S3 Compatible Storage)
# ========================================
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123
MINIO_REGION=us-east-1

# ========================================
# ELASTICSEARCH
# ========================================
ELASTIC_PASSWORD=elastic123

# ========================================
# GRAFANA
# ========================================
GRAFANA_PASSWORD=admin123

# ========================================
# K6 PERFORMANCE TESTING
# ========================================
K6_BIN=k6
K6_OUT_HTTP_API_URL=http://localhost:3001/api/performance/metrics

# ========================================
# OWASP ZAP SECURITY
# ========================================
ZAP_API_URL=http://localhost:8080
ZAP_API_KEY=zap-dev-key

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ========================================
# MONITORING
# ========================================
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
METRICS_PORT=9090

# ========================================
# DEVELOPMENT SPECIFIC
# ========================================
NEXT_TELEMETRY_DISABLED=1
DEBUG=*
BROWSER_HEADLESS=false
VIDEO_MODE=on
SCREENSHOT_MODE=on
TRACE_MODE=on