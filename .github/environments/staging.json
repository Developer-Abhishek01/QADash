{
  "name": "staging",
  "protection": "none",
  "variables": [
    {
      "name": "NODE_ENV",
      "value": "staging"
    },
    {
      "name": "LOG_LEVEL",
      "value": "info"
    },
    {
      "name": "API_URL",
      "value": "https://staging-api.qadash.io"
    },
    {
      "name": "NEXT_PUBLIC_API_URL",
      "value": "https://staging-api.qadash.io"
    }
  ],
  "secrets": [
    {
      "name": "DATABASE_URL",
      "value": "postgres://user:***@staging-db:5432/qadash"
    },
    {
      "name": "REDIS_URL",
      "value": "redis://staging-redis:6379"
    },
    {
      "name": "JWT_SECRET",
      "value": "***"
    },
    {
      "name": "STAGING_API_URL",
      "value": "https://staging-api.qadash.io"
    },
    {
      "name": "STAGING_URL",
      "value": "https://staging.qadash.io"
    },
    {
      "name": "STAGING_KUBECONFIG",
      "value": "***"
    }
  ]
}